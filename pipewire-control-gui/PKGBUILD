pkgname=pipewire-control-gui
pkgver=2.0.0
pkgrel=1
arch=('x86_64')
url="https://github.com/usrmusicman/PKGBUILDS"
license=('EULA')
depends=('pipewire' 'pipewire-jack')
optdepnds=('kdialog: A utility for displaying dialog boxes from shell scripts'
          'zenity: Display graphical dialog boxes from shell scripts')
makedepends=('git')
pkgdesc="Pipewire Session Control"
source=("Pipewire Control GUI.desktop"
        "pipewire-control-gui")
sha256sums=('65fd2ca2d3b3fb8482a1cb030eaccf6c1d5b70501e8b71041334653a7e2387e7'
            'f27c76400710e4420b61b053752071d99ad942b7782f38099f2090376a4cdf95')

package() {
    ## Install Script
    install -Dm755 "${srcdir}/pipewire-control-gui" "$pkgdir/usr/bin/pipewire-control-gui"

    ## Install Menu Entries
    install -Dm644 "${srcdir}/Pipewire Control GUI.desktop" "$pkgdir/usr/share/applications/Pipewire Control GUI.desktop"
}
