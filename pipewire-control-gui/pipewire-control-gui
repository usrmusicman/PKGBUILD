#!/bin/sh

# Dependencies: pipewire-jack, kdialog/zenity (optional)

# ------------------------------------------------------------------------------
# 1. CLI SWITCH PARSING
# ------------------------------------------------------------------------------
while [ "$#" -gt 0 ]; do
    case "$1" in
        -q) AUDIO_BUFFER="$2"; shift 2 ;;
        -r) AUDIO_SAMPLE_RATE="$2"; shift 2 ;;
        -l) APP_PATH="$2"; shift 2 ;;
        -h|--help)
            echo "Usage: sudo $0 [OPTIONS]"
            echo "  -q <quantum>    Buffer size (16-8192)"
            echo "  -r <rate>       Sample rate (44100-192000)"
            echo "  -l <cmd>        Path to application executable"
            echo "  -h <help>       Show this help message"
            exit 0 ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
done

# ------------------------------------------------------------------------------
# 2. VALIDATION & GUI/CLI FALLBACKS
# ------------------------------------------------------------------------------
validate_input() {
    val=$1; min=$2; max=$3
    if [[ "$val" =~ ^[0-9]+$ ]] && [ "$val" -ge "$min" ] && [ "$val" -le "$max" ]; then
        return 0
    fi
    return 1
}

if [ -z "$APP_PATH" ] || [ -z "$AUDIO_BUFFER" ] || [ -z "$AUDIO_SAMPLE_RATE" ]; then
    if command -v kdialog >/dev/null; then
        APP_PATH=$(kdialog --getopenfilename /usr/bin "Executable Files (*)")
        AUDIO_BUFFER=$(kdialog --combobox "Buffer" "16" "24" "32" "48" "64" "96" "128" "192" "256" "384" "512" "768" "1024" "1536" "2048" "3072" "4096" "6144" "8192")
        AUDIO_SAMPLE_RATE=$(kdialog --combobox "Rate" "44100" "48000" "88200" "96000" "192000")
    elif command -v zenity >/dev/null; then
        APP_PATH=$(zenity --file-selection --title="Select Application")
        AUDIO_BUFFER=$(zenity --list --column="Buffer" "16" "24" "32" "48" "64" "96" "128" "192" "256" "384" "512" "768" "1024" "1536" "2048" "3072" "4096" "6144" "8192")
        AUDIO_SAMPLE_RATE=$(zenity --list --column="Rate" "44100" "48000" "88200" "96000" "192000")
    else
        # CLI Selection Logic
        [ -z "$APP_PATH" ] && read -p "Enter App Path: " APP_PATH
        while ! validate_input "$AUDIO_BUFFER" 16 8192; do read -p "Enter Buffer (16-8192): " AUDIO_BUFFER; done
        while ! validate_input "$AUDIO_SAMPLE_RATE" 44100 192000; do read -p "Enter Rate (44100-192000): " AUDIO_SAMPLE_RATE; done
    fi
fi

# ------------------------------------------------------------------------------
# 3. NOTIFICATION & EXECUTION
# ------------------------------------------------------------------------------
show_notification() {
    APP_NAME=$(basename "$APP_PATH")
    MSG="Launching $APP_NAME\nLatency: ${AUDIO_BUFFER}/${AUDIO_SAMPLE_RATE}"

    if command -v kdialog >/dev/null; then
        kdialog --title "Pipewire Control GUI" --passivepopup "$MSG" 5
    elif command -v zenity >/dev/null; then
        zenity --notification --text="$MSG"
    else
        echo -e "\033[1;32m[LOG]\033[0m $MSG"
    fi
}

launch_app() {
    # Check if app exists
    if [[ ! -x "$(command -v "$APP_PATH")" && ! -f "$APP_PATH" ]]; then
        echo "Error: Binary not found."
        exit 1
    fi

    # Set PipeWire Latency Environment
    export PIPEWIRE_LATENCY="${AUDIO_BUFFER}/${AUDIO_SAMPLE_RATE}"

    # 2026 High-Performance Environment Variables
    export PROTON_USE_WOW64=1
    export WINENTSYNC=1
    export XDG_SESSION_TYPE=wayland

    show_notification

    # Launch with SCX Scheduler and Mode
    "$APP_PATH"

}

launch_app
