# Maintainer: Your Name <your@email.com>
# Sysctl Tweaks

pkgbase=archlinux-deckify
pkgname=("${pkgbase}-git" "${pkgbase}-database-git")
_pkgname=ArchLinuxDeckify
pkgver=r104.652752c
pkgrel=1
arch=('any')
url="https://github.com/usrmusicman/ArchLinuxDeckify"
license=('GPL')
makedepends=('git')
source=("git+${url}.git")
sha256sums=('SKIP')

pkgver() {
  cd "$_pkgname"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package_archlinux-deckify-git() {
  depends=('catimg' 'gamemode' 'gamescope' 'steam' 'steam-devices' 'bash' 'realtime-privileges' 'sudo' 'scx-scheds' 'scx-tools' 'pipewire' 'iw' 'udiskie')
  pkgdesc="Modular SteamOS-like session for Arch with centralized configuration and profile templates"
  provides=("$pkgbase-git")
  conflicts=("$pkgbase-git")
  install="$pkgbase-git.install"

  optdepends=(
    'nvidia-utils: For Nvidia GPU support'
    'gdm: For automatic login support'
    'lightdm: For automatic login support'
    'lib32-gamemode: For regular gamemode 32-bit support'
    'lib32-nvidia-utils: For Nvidia 32-bit gaming'
    'lib32-vulkan-radeon: For AMD Vulkan 32-bit support'
    'lib32-vulkan-intel: For Intel GPU 32-bit support'
    'pipewire-control-gui: For the Audio Session Control'
    'plasma-login-manager: For automatic login support'
    'sddm: For automatic login support'
    'xf86-video-amdgpu: For AMD GPU support'
    'vulkan-radeon: For AMD Vulkan support'
    'vulkan-intel: For Intel GPU support'
  )

  cd "$_pkgname"

  # Create Directories
  mkdir -p "$pkgdir/etc/systemd/system/getty@tty1.service.d"
  mkdir -p "$pkgdir/etc/sudoers.d"
  mkdir -p "$pkgdir/etc/sysctl.d"
  mkdir -p "$pkgdir/usr/bin"

  # Install scripts, and hardware startup configs
  install -Dm755 $srcdir/ArchLinuxDeckify/steamos-deckify-toggle "$pkgdir/opt/steamos-session/steamos-deckify-toggle"
  install -Dm755 $srcdir/ArchLinuxDeckify/steamos-gamemode-enhanced "$pkgdir/opt/steamos-session/steamos-gamemode-enhanced"
  install -Dm755 $srcdir/ArchLinuxDeckify/steamos-session-launcher "$pkgdir/opt/steamos-session/steamos-session-launcher"
  install -Dm755 $srcdir/ArchLinuxDeckify/steamos-session-select "$pkgdir/opt/steamos-session/steamos-session-select"
  install -Dm755 $srcdir/ArchLinuxDeckify/config/session/hardware/default/1080p-60 "$pkgdir/opt/steamos-session/config/session/hardware/default/1080p-60"
  install -Dm755 $srcdir/ArchLinuxDeckify/config/session/hardware/default/1440p-60 "$pkgdir/opt/steamos-session/config/session/hardware/default/1440p-60"
  install -Dm755 $srcdir/ArchLinuxDeckify/config/session/hardware/default/2160p-60 "$pkgdir/opt/steamos-session/config/session/hardware/default/2160p-60"

  # Install the bash .profile templates
  install -Dm644 $srcdir/ArchLinuxDeckify/config/bash/.bash_profile.deckify "$pkgdir/opt/steamos-session/config/bash/.bash_profile.deckify"
  install -Dm644 $srcdir/ArchLinuxDeckify/config/bash/.bash_profile.normal "$pkgdir/opt/steamos-session/config/bash/.bash_profile.normal"

  # Install the associated assets
  install -Dm644 $srcdir/ArchLinuxDeckify/assets/icons/steamos-session-icon.png "$pkgdir/opt/steamos-session/assets/icons/steamos-session-icon.png"

  # Create symlink
  ln -s /opt/steamos-session/steamos-deckify-toggle "$pkgdir/usr/bin/steamos-deckify-toggle"
  ln -s /opt/steamos-session/steamos-gamemode-enhanced "$pkgdir/usr/bin/steamos-gamemode-enhanced"
  ln -s /opt/steamos-session/steamos-session-launcher "$pkgdir/usr/bin/steamos-session-launcher"
  ln -s /opt/steamos-session/steamos-session-select "$pkgdir/usr/bin/steamos-session-select"

  # 5. Install sudoers override file
  cat <<EOF > "$pkgdir/etc/sudoers.d/10-steamos-session-overrides"
# SteamOS Enhanced Gamemode
%wheel ALL=(ALL) NOPASSWD: /opt/steamos-session/steamos-gamemode-enhanced
EOF

chmod 440 $pkgdir/etc/sudoers.d/10-steamos-session-overrides

  # 6. Install Getty Override Template
  cat <<EOF > "$pkgdir/etc/systemd/system/getty@tty1.service.d/override.conf"
[Service]
ExecStart=
ExecStart=-/sbin/agetty --autologin @USER@ --noclear %I 38400 linux
EOF

   # 7. Sysctl Tweaks
   cat <<EOF > "$pkgdir/etc/sysctl.d/10-memory.conf"
# Lower swappiness to favor RAM for your creative apps
vm.swappiness = 1
# Reluctantly reclaim file system caches for snappier navigation
vm.vfs_cache_pressure = 50
EOF

   cat <<EOF > "$pkgdir/etc/sysctl.d/20-responsiveness.conf"
# Allow more memory maps (Critical for heavy Steam games and Wine)
vm.max_map_count = 1048576
EOF

   cat <<EOF > "$pkgdir/etc/sysctl.d/30-network.conf"
# Increases the maximum number of packets queued on the input side.
net.core.netdev_max_backlog = 5000
# Reduces the handshake overhead for connections.
net.ipv4.tcp_fastopen = 3
EOF

   cat <<EOF > "$pkgdir/etc/sysctl.d/40-rt_preempt.conf"
# Give RT threads 100% of CPU time
kernel.sched_rt_runtime_us = -1
# NUMA Balancing
kernel.numa_balancing = 0
EOF

   cat <<EOF > "$pkgdir/etc/sysctl.d/50-timers.conf"
# Increases the interval (in seconds) at which the kernel gathers VM statistics.
vm.stat_interval = 10
# On multi-core systems, the kernel tries to move timers to idle CPUs to save power.
kernel.timer_migration = 0
EOF

  # 8. Install Pacman Hook for Gamescope Capabilities
  mkdir -p "$pkgdir/usr/share/libalpm/hooks"
  cat <<EOF > "$pkgdir/usr/share/libalpm/hooks/gamescope-capabilities.hook"
[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = gamescope

[Action]
Description = Restoring setcap 'cap_sys_nice=eip' to gamescope...
When = PostTransaction
Exec = /usr/bin/setcap 'cap_sys_nice=eip' /usr/bin/gamescope
EOF
}

package_archlinux-deckify-database-git() {
  depends=("archlinux-deckify-git")
  pkgdesc="Modular SteamOS-like session for Arch (Profile Database)"
  provides=("$pkgbase-database-git")
  conflicts=("$pkgbase-database-git")

  mkdir -p $pkgdir/opt/steamos-session/config/session/hardware
  cp -rvf $srcdir/ArchLinuxDeckify/config/session/hardware/amdgpu-sapphire-rx9070xt $pkgdir/opt/steamos-session/config/session/hardware
  cp -rvf $srcdir/ArchLinuxDeckify/config/session/hardware/amdgpu-valve-steamdeck $pkgdir/opt/steamos-session/config/session/hardware
  cp -rvf $srcdir/ArchLinuxDeckify/config/session/hardware/nvidia-acer-nitrov15 $pkgdir/opt/steamos-session/config/session/hardware
  cp -rvf $srcdir/ArchLinuxDeckify/config/session/hardware/nvidia-fe-rtx2080ti $pkgdir/opt/steamos-session/config/session/hardware
  cp -rvf $srcdir/ArchLinuxDeckify/config/session/hardware/nvidia-pny-rtx4080super $pkgdir/opt/steamos-session/config/session/hardware
  cp -rvf $srcdir/ArchLinuxDeckify/config/session/hardware/xe-asrock-b580 $pkgdir/opt/steamos-session/config/session/hardware
  cp -rvf $srcdir/ArchLinuxDeckify/config/session/hardware/xe-le-a770 $pkgdir/opt/steamos-session/config/session/hardware
}
